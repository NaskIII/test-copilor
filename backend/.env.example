# ──────────────────────────────────────────────
# Configuração da aplicação FinançasPro – Backend
# Copie este arquivo para ".env" e ajuste os valores
# ──────────────────────────────────────────────

# ────────────── Banco de Dados ──────────────
# Por padrão (desenvolvimento) usa SQLite:
#   Um arquivo "finance.db" é criado automaticamente na pasta backend/
DATABASE_URL=sqlite:///./finance.db

# Para usar PostgreSQL em produção, comente a linha acima e use:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/financaspro

# ────────────── JWT / Segurança ──────────────
# Chave secreta para assinar os tokens JWT.
# Gere uma chave segura com:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-chave-segura-gerada-aleatoriamente

# Algoritmo de assinatura do JWT (não altere sem necessidade)
ALGORITHM=HS256

# Tempo de expiração do token de acesso (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ────────────── CORS ──────────────
# Origens permitidas (separadas por vírgula) para o frontend
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
